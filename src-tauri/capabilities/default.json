{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability for Personal Finance Manager",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$APPDATA/finance.db" },
        { "path": "$APPLOCALDATA/finance.db" },
        { "path": "$APPCONFIG/finance.db" }
      ]
    },
    "fs:allow-write-text-file",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-select"
  ]
}
